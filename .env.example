DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/thecee
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=thecee

# development | production (CORS and hardening)
ENVIRONMENT=development

# JWT — use a long random string in production (e.g. `openssl rand -hex 32`)
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Sentry (optional; leave empty in local dev)
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# Comma-separated emails allowed to call GET /api/v1/analytics/platform (or set is_admin in DB)
ADMIN_EMAILS=

# CORS — set to your deployed Vercel URL in production
FRONTEND_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_ALLOW_INDEXING=false

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2

# Database pool / timeout tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=30000

# pgvector dimension (default matches OpenAI text-embedding-3-small)
VECTOR_DIMENSION=1536

# Conductor: parallel / fan-out hint (in-process; pair with app deployment sizing)
CONDUCTOR_WORKERS=4

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Subscription Plan IDs (create in Razorpay dashboard) ──
RAZORPAY_PRO_PLAN_ID=plan_xxxxxxxxxxxx
RAZORPAY_ENTERPRISE_PLAN_ID=plan_xxxxxxxxxxxx
