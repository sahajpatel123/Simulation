# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python backend (thecee-backend)
venv/
.venv/
.venv2/
__pycache__/
*.pyc
*.egg-info/
dist/

# iCloud duplicate files (e.g. "file 2.py")
* 2.py
* 2.sh
* 2.txt
.gitkeep 2
thecee-backend/
