# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# iCloud duplicate filenames
* 2.env*
* 2.local
* 2.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python backend (thecee-backend)
venv/
.venv/
.venv2/
__pycache__/
*.pyc
*.egg-info/
dist/

# iCloud duplicate files (catch all extensions, any nesting)
* 2.*
**/* 2.*
* 2
**/* 2
thecee-backend/

# Root-level Python shadow (runtime uses backend/ exclusively)
/app/
/scripts/
.venv_step86/
.next.nosync/

# Claude AI tooling — personal workspace data, not project code
.claude/

# External reference code (Lovable open-source engine), not integrated
/Lovable/
**/Lovable/

# One-off patch scripts (already applied, kept for history only)
/bulk_replace.py
/patch_api_common.py
/patch_prompts.py
/patch_prompts_v2.py
/patch_ui_builder.py

# Audit reports — security documentation (keep tracked, ignore future copies)
/AUDIT_REPORT* 2*.md
/SECURITY_AUDIT* 2*.md

# Empty migrations placeholder (real migrations via migrate_and_start.py)
/migrations/
